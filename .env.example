# .env 파일 예시 → .env 로 복사 후 본인 환경에 맞게 수정
# 팀원마다 API 제공자가 다를 수 있으므로 아래 옵션 중 하나 선택

# ────────────────────────────────────────────────
# 옵션 1: Google Gemini 무료 API
# 발급: https://aistudio.google.com/app/apikey
# ────────────────────────────────────────────────
# API_KEY=Gemini_API_키
# GATEWAY_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# INDEX_MODEL=gemini-2.5-flash-lite
# QUERY_MODEL=gemini-2.5-flash-lite

# ────────────────────────────────────────────────
# 옵션 2: OpenAI 직접 사용
# ────────────────────────────────────────────────
# API_KEY=sk-...
# GATEWAY_URL=               ← 비워두면 OpenAI 기본값 사용
# INDEX_MODEL=gpt-4o-mini
# QUERY_MODEL=gpt-4o

# ────────────────────────────────────────────────
# 공통 설정
# ────────────────────────────────────────────────
API_KEY=your_api_key_here
GATEWAY_URL=your_gateway_url_here
INDEX_MODEL=gemini-2.5-flash-lite
QUERY_MODEL=gemini-2.5-flash-lite

# Neo4j (선택, 없으면 로컬 파일 스토리지 사용)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
